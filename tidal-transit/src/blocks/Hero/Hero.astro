            <li><img width="30" height="30" loading="lazy"
                src="./images/advantages/5000ремонт-removebg-preview.webp" alt=""> 5000+ Ремонтів </li>
            <li><img width="30" height="30" loading="lazy" src="./images/advantages/4розробки-removebg-preview.webp"
                alt=""> 4 Власних інженерних розробки</li>
          </ul>
        </div>

        <div class="col-md-6 text-center" data-aos="fade-left" data-aos-delay="400">
          <img loading="lazy" width="400" height="400" src="./images/drone-1.webp" alt="" />
        </div>

